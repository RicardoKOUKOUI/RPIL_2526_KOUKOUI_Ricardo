# Configuration de la base de données MySQL
# Copier ce fichier en .env et remplir avec vos vraies valeurs

# Hôte de la base de données (localhost pour développement local)
DB_HOST=127.0.0.1

# Nom d'utilisateur MySQL
DB_USER=mentoruser

# Mot de passe MySQL
DB_PASSWORD=mentorpass

# Nom de la base de données
DB_NAME=mentorapp

# Port MySQL (optionnel, par défaut 3306)
# DB_PORT=3306